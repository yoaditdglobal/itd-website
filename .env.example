# Copy to .env.local (dev) and set the same vars in the Netlify dashboard (prod).
# NEVER commit real secrets. NEXT_PUBLIC_* are exposed to the browser by design.

# ── Anthropic (Connexx chat assistant) ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Zoho CRM (EU data centre) — leads + support cases ───────────────────────
# Self Client refresh token from api-console.zoho.eu. Hosts default to EU if unset.
ZOHO_ACCOUNTS_HOST=https://accounts.zoho.eu
ZOHO_API_HOST=https://www.zohoapis.eu
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── Microsoft Graph (email send) ────────────────────────────────────────────
# Entra app with application Mail.Send (admin-consented), restricted to the
# sender mailbox via an application access policy.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_UPN=website@itdglobal.com

# Internal notification recipients
LEADS_NOTIFY_TO=sales@itdglobal.com
SUPPORT_NOTIFY_TO=support@itdglobal.com

# ── Chat widget ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BOOKING_URL=
